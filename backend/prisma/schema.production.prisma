datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Institute {
  id                 String   @id @default(uuid())
  name               String
  address            String
  branches           String
  registrationStatus String
  paymentStatus      String
  paymentType        String?
  createdAt          DateTime @default(now())
}

model Student {
  id               String   @id @default(uuid())
  name             String
  rollNo           String   @unique
  email            String   @unique
  instituteId      String
  branch           String
  year             Int
  passwordHash     String
  showNamePublic   Boolean  @default(true)
  createdAt        DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String
  instituteId  String?
  createdAt    DateTime @default(now())
}

model Event {
  id               String   @id @default(uuid())
  instituteId      String
  instituteName    String
  title            String
  description      String
  bannerUrl        String
  eventDate        DateTime
  category         String
  registrationLink String?
  createdAt        DateTime @default(now())
}

model EventLike {
  id        String   @id @default(uuid())
  eventId   String
  studentId String
  createdAt DateTime @default(now())

  @@unique([eventId, studentId])
}

model EventComment {
  id          String   @id @default(uuid())
  eventId     String
  studentId   String
  studentName String
  commentText String
  createdAt   DateTime @default(now())
  isDeleted   Boolean  @default(false)
}

model Test {
  id              String   @id @default(uuid())
  branch          String
  title           String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  createdBy       String
  createdAt       DateTime @default(now())
}

model Question {
  id            String   @id @default(uuid())
  testId        String
  questionText  String
  options       String
  correctOption Int
  marks         Int
  questionType  String
}

model TestAttempt {
  id             String    @id @default(uuid())
  testId         String
  studentId      String
  answers        String
  score          Int       @default(0)
  submittedAt    DateTime?
  status         String
  tabSwitchCount Int       @default(0)
  createdAt      DateTime  @default(now())

  @@unique([testId, studentId])
}

model TabSwitchLog {
  id           String   @id @default(uuid())
  testId       String
  studentId    String
  switchNumber Int
  timestamp    DateTime @default(now())
}

model LeaderboardEntry {
  id            String   @id @default(uuid())
  testId        String
  studentId     String
  studentName   String
  rollNo        String
  instituteId   String
  instituteName String
  rank          Int
  score         Int
  branch        String
  submittedAt   DateTime @default(now())

  @@unique([testId, studentId])
}
