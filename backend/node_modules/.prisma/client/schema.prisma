datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Institute {
  id                 String   @id @default(uuid())
  name               String
  address            String
  branches           String // Comma-separated branches (e.g., "CSE,ECE,MECH,CIVIL")
  registrationStatus String // "PENDING", "APPROVED", "REJECTED"
  paymentStatus      String // "UNPAID", "PAID"
  paymentType        String? // "ONE_TIME", "ANNUAL_SUBSCRIPTION"
  createdAt          DateTime @default(now())
}

model Student {
  id             String   @id @default(uuid())
  name           String
  rollNo         String   @unique
  email          String   @unique
  instituteId    String
  branch         String
  year           Int
  passwordHash   String
  showNamePublic Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String // "SUPER_ADMIN", "INSTITUTE_ADMIN"
  instituteId  String? // Null for Super Admin
  createdAt    DateTime @default(now())
}

model Event {
  id               String   @id @default(uuid())
  instituteId      String
  instituteName    String
  title            String
  description      String
  bannerUrl        String
  eventDate        DateTime
  category         String
  registrationLink String?
  createdAt        DateTime @default(now())
}

model EventLike {
  id        String   @id @default(uuid())
  eventId   String
  studentId String
  createdAt DateTime @default(now())

  @@unique([eventId, studentId])
}

model EventComment {
  id          String   @id @default(uuid())
  eventId     String
  studentId   String
  studentName String
  commentText String
  createdAt   DateTime @default(now())
  isDeleted   Boolean  @default(false)
}

model Test {
  id              String   @id @default(uuid())
  branch          String // e.g., "CSE", "ECE", "MECH" (or "ALL")
  title           String
  startTime       DateTime
  endTime         DateTime
  durationMinutes Int
  createdBy       String
  createdAt       DateTime @default(now())
}

model Question {
  id            String @id @default(uuid())
  testId        String
  questionText  String
  options       String // JSON stringified array of options: '["A", "B", "C", "D"]'
  correctOption Int // Index of correct option (0, 1, 2, 3)
  marks         Int
  questionType  String // "MCQ" or "CODING"
}

model TestAttempt {
  id             String    @id @default(uuid())
  testId         String
  studentId      String
  answers        String // JSON stringified student answers: '{"questionId": selectedOptionIndex}'
  score          Int       @default(0)
  submittedAt    DateTime?
  status         String // "IN_PROGRESS", "COMPLETED", "AUTO_SUBMITTED", "DISQUALIFIED"
  tabSwitchCount Int       @default(0)
  createdAt      DateTime  @default(now())

  @@unique([testId, studentId])
}

model TabSwitchLog {
  id           String   @id @default(uuid())
  testId       String
  studentId    String
  switchNumber Int
  timestamp    DateTime @default(now())
}

model LeaderboardEntry {
  id            String   @id @default(uuid())
  testId        String
  studentId     String
  studentName   String
  rollNo        String
  instituteId   String
  instituteName String
  rank          Int
  score         Int
  branch        String
  submittedAt   DateTime @default(now())

  @@unique([testId, studentId])
}
